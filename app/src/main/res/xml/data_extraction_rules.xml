<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude SharedPreferences — contain auth tokens and API keys -->
        <exclude domain="sharedpref" path="." />
        <!-- Exclude Room database — re-syncs from Firestore on login -->
        <exclude domain="database" path="." />
        <!-- Cache excluded automatically -->
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
