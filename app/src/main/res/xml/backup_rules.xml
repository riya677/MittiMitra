<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude all SharedPreferences from cloud backup — they contain auth tokens and keys -->
    <exclude domain="sharedpref" path="." />
    <!-- Exclude Room database — re-syncs from Firestore on login -->
    <exclude domain="database" path="." />
    <!-- Exclude cached camera images -->
    <exclude domain="cache" path="camera_images" />
</full-backup-content>